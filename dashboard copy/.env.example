# Dashboard mode: `mock` for offline UI development, `live` for Jetson/backend integration
NEXT_PUBLIC_DATA_SOURCE=mock

# ── Signaling ────────────────────────────────────────────────────────

# Signaling mode:
#   direct — browser connects straight to the Jetson's WebSocket (same LAN / VPN)
#   relay  — both browser and Jetson connect to a public relay server
#            (required when they are on different networks, e.g. 4G ↔ campus Wi-Fi)
NEXT_PUBLIC_SIGNALING_MODE=direct

# WebSocket endpoint.
#   direct mode  → the Jetson's WS URL (e.g. ws://192.168.1.42:8080)
#   relay mode   → the public relay URL (e.g. wss://relay.your-domain.com/ws)
NEXT_PUBLIC_WS_URL=wss://your-server-domain/ws

# Drone ID used by the relay to pair dashboard ↔ Jetson connections.
NEXT_PUBLIC_DRONE_ID=drone-01

# Optional bearer token the relay checks on registration.
NEXT_PUBLIC_RELAY_AUTH_TOKEN=

# REST API base URL served by the Node.js backend
NEXT_PUBLIC_API_BASE_URL=https://your-server-domain/api

# ── ICE / TURN ───────────────────────────────────────────────────────

# STUN servers (comma-separated).  Defaults to Google's public STUN if empty.
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302

# TURN servers — critical for cross-network / symmetric NAT.
# Include both UDP and TCP transports for maximum reach.
NEXT_PUBLIC_TURN_URLS=turn:turn.your-server-domain:3478?transport=udp,turn:turn.your-server-domain:3478?transport=tcp,turns:turn.your-server-domain:5349?transport=tcp
NEXT_PUBLIC_TURN_USERNAME=demo-user
NEXT_PUBLIC_TURN_CREDENTIAL=demo-password

# Force all media through TURN relay (no direct P2P attempts).
# Set to true for strict enterprise / campus networks.
NEXT_PUBLIC_FORCE_TURN=false
