# WebSocket endpoint served by the Node.js telemetry bridge
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# REST API base URL served by the Node.js backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Video transport to use on the Vision page: "webrtc" or "livekit"
NEXT_PUBLIC_VIDEO_TRANSPORT=webrtc

# LiveKit room connection for dashboard video
NEXT_PUBLIC_LIVEKIT_URL=wss://your-livekit-server
NEXT_PUBLIC_LIVEKIT_ROOM=drone-1
NEXT_PUBLIC_LIVEKIT_TOKEN_ENDPOINT=/api/livekit/token

# Server-side only: token generation for LiveKit
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-server

# MediaMTX embed configuration for annotated browser playback
NEXT_PUBLIC_MEDIAMTX_WEBRTC_BASE_URL=http://YOUR_MEDIAMTX_HOST:8889
NEXT_PUBLIC_MEDIAMTX_HLS_BASE_URL=http://YOUR_MEDIAMTX_HOST:8888
NEXT_PUBLIC_MEDIAMTX_EMBED_PROTOCOL=webrtc
NEXT_PUBLIC_MEDIAMTX_TOP_PATH=drone-top
NEXT_PUBLIC_MEDIAMTX_SIDE_PATH=drone-side
